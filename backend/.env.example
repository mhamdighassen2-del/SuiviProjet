# ============================================================
#  .env.example  —  Copier en .env et remplir les valeurs
# ============================================================

# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=suivi_projets
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# JWT
JWT_SECRET=changer_cette_valeur_en_production_avec_64_chars_minimum
JWT_EXPIRES_IN=8h

# Upload fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
