{
  "name": "suivi-projets-backend",
  "version": "1.0.0",
  "description": "API backend - Suivi projets industriels",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:verify": "node scripts/verify-db-connection.js",
    "setup:db-password": "node scripts/setup-db-password.js",
    "db:create": "node scripts/create-database.js",
    "db:migrate": "node scripts/run-sql-file.js ../database/migrations/001_init.sql",
    "db:migrate:002": "node scripts/run-sql-file.js ../database/migrations/002_ordre_fabrication_projet_cascade.sql",
    "db:migrate:003": "node scripts/run-sql-file.js ../database/migrations/003_utilisateur_service.sql",
    "db:seed": "node scripts/run-sql-file.js ../database/seeds/seed.sql",
    "db:setup": "npm run db:create && npm run db:migrate && npm run db:migrate:002 && npm run db:migrate:003 && npm run db:seed",
    "docker:up": "docker compose -f ../docker-compose.yml up -d"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.10.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
